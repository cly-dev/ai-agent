# Copy one template per environment:
# - .env       (development)
# - .env.test  (test)
# - .env.prod  (production)

# PostgreSQL (required)
DATABASE_URL=postgresql://user:pass@localhost:5432/agent

# Auth
JWT_SECRET=change-me
JWT_EXPIRES_IN=7d

# Redis (optional)
# If REDIS_URL and REDIS_HOST are both empty, memory stores are read-only fallback.
REDIS_URL=redis://localhost:6379
REDIS_HOST=
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# Memory TTL
# user memory: 0 means never expire
MEMORY_USER_TTL_SECONDS=0
# session context: must be > 0
MEMORY_SESSION_TTL_SECONDS=604800
