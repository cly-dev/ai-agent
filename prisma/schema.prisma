// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum ToolLevel {
  L1
  L2
  L3
}

enum HttpMethod{
  Get
  Post
  Put
  Delete
}

enum UserType {
  C_END
  B_END
}

enum UserRole {
  C_END_USER
  CUSTOMER_SERVICE
  OPERATOR
}

enum AdminRole {
  SUPER_ADMIN
  OPERATOR
  VIEWER
}

model User {
  id        Int      @id @default(autoincrement())
  email     String
  password  String
  username  String
  userType  UserType @default(C_END)
  userRole  UserRole?
  mustChangePassword Boolean @default(true)
  createdAt DateTime @default(now())

  sessions        Session[]
  llmModelConfigs UserLlmModelConfig[]
  @@index([userType])
  @@index([userRole])
}


model Role {
  id          Int      @id @default(autoincrement())
  name        String   @unique
  description String?
  allowToolLevel ToolLevel @default(L1)
  createdAt   DateTime @default(now())

  roleSkills RoleSkill[]

  @@map("role")
}

model AdminUser {
  id        Int       @id @default(autoincrement())
  email     String    @unique
  password  String
  username  String
  role      AdminRole
  isActive  Boolean   @default(true)
  mustChangePassword Boolean @default(true)
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
}

model AppClient {
  id          Int      @id @default(autoincrement())
  name        String
  dsn         String   @unique
  description String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model LlmModelConfig {
  id           Int      @id @default(autoincrement())
  singletonKey Int      @unique @default(1)
  provider     String   @default("openai-compatible")
  model        String
  apiKey       String?
  baseUrl      String
  chatPath     String   @default("/v1/chat/completions")
  parameters   Json?
  stream       Boolean  @default(false)
  maxTokens    Int?
  temperature  Float?
  enabled      Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model UserLlmModelConfig {
  id          Int      @id @default(autoincrement())
  userId      Int
  provider    String
  model       String
  apiKey      String
  baseUrl     String?
  temperature Float?
  maxTokens   Int?
  enabled     Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model Session {
  id        Int      @id @default(autoincrement())
  userId    Int
  agentId   Int?
  title     String?
  createdAt DateTime @default(now())

  user     User      @relation(fields: [userId], references: [id])
  messages Message[]

  @@index([userId])
}

model Message {
  id        Int     @id @default(autoincrement())
  sessionId Int
  role      String // user / assistant / tool / system
  content   String?

  toolName   String?
  toolInput  Json?
  toolOutput Json?

  createdAt DateTime @default(now())

  session Session @relation(fields: [sessionId], references: [id])

  @@index([sessionId])
}

/// 工具业务分类（商品、订单、搜索等），由用户在后台自由增删
model ToolCategory {
  id          Int      @id @default(autoincrement())
  label       String
  description String?
  sortOrder   Int      @default(0)
  tools       Tool[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([sortOrder])
}

model Tool {
  id          Int      @id @default(autoincrement())
  name        String
  description String
  riskLevel   ToolLevel @default(L1)
  schema      Json // 参数结构
  skillTools SkillTool[]
  inputSchema   Json
  outputSchema  Json?
  method        HttpMethod
  path          String
  integrationId Int
  integration   Integration @relation(fields: [integrationId], references: [id])
  toolCategoryId Int?
  toolCategory   ToolCategory? @relation(fields: [toolCategoryId], references: [id], onDelete: SetNull)
  userRoleTools UserRoleTool[]
  isActive      Boolean  @default(true)
  timeout       Int?    
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([toolCategoryId])
}
model Integration{
   id        Int      @id @default(autoincrement())
  name      String
  baseUrl   String

  // 认证信息（先简单做）
  apiKey    String

  tools     Tool[]

  createdAt DateTime @default(now())
}

model Skill {
  id          Int      @id @default(autoincrement())
  name        String
  description String?
  prompt      String
  config      Json?
  createdAt   DateTime @default(now())

  skillTools  SkillTool[]
  agentSkills AgentSkill[]
  roleSkills  RoleSkill[]
}

model RoleSkill {
  id      Int @id @default(autoincrement())
  roleId  Int
  skillId Int

  role  Role  @relation(fields: [roleId], references: [id])
  skill Skill @relation(fields: [skillId], references: [id])

  @@unique([roleId, skillId])
  @@map("roleskill")
}

model SkillTool {
  id      Int @id @default(autoincrement())
  skillId Int
  toolId  Int

  skill Skill @relation(fields: [skillId], references: [id])
  tool  Tool  @relation(fields: [toolId], references: [id])

  @@unique([skillId, toolId])
}

model UserRoleTool {
  id        Int      @id @default(autoincrement())
  userRole  UserRole
  toolId    Int
  createdAt DateTime @default(now())

  tool Tool @relation(fields: [toolId], references: [id])

  @@unique([userRole, toolId])
  @@index([toolId])
}

model Agent {
  id        Int      @id @default(autoincrement())
  name      String
  config    Json?
  createdAt DateTime @default(now())

  agentSkills AgentSkill[]
}

model AgentSkill {
  id      Int @id @default(autoincrement())
  agentId Int
  skillId Int

  agent Agent @relation(fields: [agentId], references: [id])
  skill Skill @relation(fields: [skillId], references: [id])

  @@unique([agentId, skillId])
}
