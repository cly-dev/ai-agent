// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum ToolLevel {
  L1
  L2
  L3
}

enum HttpMethod{
  Get
  Post
  Put
  Delete
}

enum UserType {
  C_END
  B_END
}

enum UserRole {
  C_END_USER
  CUSTOMER_SERVICE
  OPERATOR
}

enum AdminRole {
  SUPER_ADMIN
  OPERATOR
  VIEWER
}

enum AgentRunStatus {
  running
  success
  failed
}

model User {
  id        Int      @id @default(autoincrement())
  email     String
  password  String
  username  String
  userType  UserType @default(C_END)
  userRole  UserRole?
  mustChangePassword Boolean @default(true)
  createdAt DateTime @default(now())

  sessions        Session[]
  llmModelConfigs UserLlmModelConfig[]
  userApps        UserApp[]
  @@index([userType])
  @@index([userRole])
}


model Role {
  id          Int      @id @default(autoincrement())
  name        String   @unique
  description String?
  allowToolLevel ToolLevel @default(L1)
  createdAt   DateTime @default(now())

  roleSkills RoleSkill[]
  userApps   UserApp[]
  roleTools RoleTool[]

  @@map("role")
}

model AdminUser {
  id        Int       @id @default(autoincrement())
  email     String    @unique
  password  String
  username  String
  role      AdminRole
  isActive  Boolean   @default(true)
  mustChangePassword Boolean @default(true)
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
}

model AppClient {
  id          Int      @id @default(autoincrement())
  name        String
  dsn         String   @unique
  description String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  agents       Agent[]
  tools        Tool[]
  sessions     Session[]
  agentRuns    AgentRun[]
  integrations Integration[]
  userApps     UserApp[]
}

model LlmModelConfig {
  id           Int      @id @default(autoincrement())
  singletonKey Int      @unique @default(1)
  provider     String   @default("openai-compatible")
  model        String
  apiKey       String?
  baseUrl      String
  chatPath     String   @default("/v1/chat/completions")
  parameters   Json?
  stream       Boolean  @default(false)
  maxTokens    Int?
  temperature  Float?
  enabled      Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model UserLlmModelConfig {
  id          Int      @id @default(autoincrement())
  userId      Int
  provider    String
  model       String
  apiKey      String
  baseUrl     String?
  temperature Float?
  maxTokens   Int?
  enabled     Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model Session {
  id        String   @id @db.VarChar(32)
  userId    Int
  appClientId Int
  agentId   Int?
  title     String?
  createdAt DateTime @default(now())

  user      User       @relation(fields: [userId], references: [id])
  appClient AppClient  @relation(fields: [appClientId], references: [id])
  messages  Message[]
  agentRuns AgentRun[]

  @@index([userId])
  @@index([appClientId])
}

model Message {
  id        Int     @id @default(autoincrement())
  sessionId String
  role      String // user / assistant / tool / system
  content   String?

  toolName   String?
  toolInput  Json?
  toolOutput Json?

  createdAt DateTime @default(now())

  session Session @relation(fields: [sessionId], references: [id])

  @@index([sessionId])
}

/// 工具业务分类（商品、订单、搜索等），由用户在后台自由增删
model ToolCategory {
  id          Int      @id @default(autoincrement())
  label       String
  description String?
  sortOrder   Int      @default(0)
  tools       Tool[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([sortOrder])
}

model Tool {
  id          Int      @id @default(autoincrement())
  appClientId Int
  name        String
  description String
  riskLevel   ToolLevel @default(L1)
  schema      Json // 参数结构
  skillTools SkillTool[]
  inputSchema   Json
  outputSchema  Json?
  method        HttpMethod
  path          String
  integrationId Int
  integration   Integration @relation(fields: [integrationId], references: [id])
  appClient     AppClient   @relation(fields: [appClientId], references: [id])
  toolCategoryId Int?
  toolCategory   ToolCategory? @relation(fields: [toolCategoryId], references: [id], onDelete: SetNull)
  roleTools     RoleTool[]
  isActive      Boolean  @default(true)
  timeout       Int?    
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([toolCategoryId])
  @@index([appClientId])
}
model Integration{
   id        Int      @id @default(autoincrement())
  appClientId Int
  name      String
  baseUrl   String

  // 认证信息（先简单做）
  apiKey    String

  appClient AppClient @relation(fields: [appClientId], references: [id])
  tools     Tool[]

  createdAt DateTime @default(now())

  @@index([appClientId])
}

model Skill {
  id          Int      @id @default(autoincrement())
  name        String
  description String?
  prompt      String
  config      Json?
  createdAt   DateTime @default(now())

  skillTools  SkillTool[]
  agentSkills AgentSkill[]
  roleSkills  RoleSkill[]
}

model RoleSkill {
  id      Int @id @default(autoincrement())
  roleId  Int
  skillId Int

  role  Role  @relation(fields: [roleId], references: [id])
  skill Skill @relation(fields: [skillId], references: [id])

  @@unique([roleId, skillId])
  @@map("roleskill")
}

model SkillTool {
  id      Int @id @default(autoincrement())
  skillId Int
  toolId  Int

  skill Skill @relation(fields: [skillId], references: [id])
  tool  Tool  @relation(fields: [toolId], references: [id])

  @@unique([skillId, toolId])
}

model UserApp {
  id          Int      @id @default(autoincrement())
  userId      Int
  appId       Int
  roleId      Int
  createdAt   DateTime @default(now())

  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  appClient   AppClient @relation(fields: [appId], references: [id], onDelete: Cascade)
  role        Role      @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@unique([userId, appId])
  @@index([userId])
  @@index([appId])
  @@index([roleId])
}

model RoleTool {
  id        Int      @id @default(autoincrement())
  roleId    Int
  toolId    Int
  createdAt DateTime @default(now())

  role      Role @relation(fields: [roleId], references: [id], onDelete: Cascade)
  tool      Tool @relation(fields: [toolId], references: [id], onDelete: Cascade)

  @@unique([roleId, toolId])
  @@index([roleId])
  @@index([toolId])
}

model Agent {
  id             Int      @id @default(autoincrement())
  appClientId    Int
  name           String
  description    String?
  systemPrompt   String
  toolIds        Int[]    @default([])
  maxSteps       Int      @default(8)
  enableToolCall Boolean  @default(true)
  config         Json?
  createdAt      DateTime @default(now())

  appClient   AppClient    @relation(fields: [appClientId], references: [id])
  agentSkills AgentSkill[]
  agentRuns   AgentRun[]

  @@index([appClientId])
}

model AgentRun {
  id          Int            @id @default(autoincrement())
  agentId     Int
  appClientId Int
  sessionId   String
  input       String
  output      String?
  status      AgentRunStatus @default(running)
  steps       Json
  currentStep Int            @default(0)
  maxSteps    Int
  error       String?
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt

  agent Agent @relation(fields: [agentId], references: [id], onDelete: Cascade)
  appClient AppClient @relation(fields: [appClientId], references: [id])
  session Session @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  
  @@index([sessionId])
  @@index([agentId])
  @@index([appClientId])
  @@index([status])
  @@index([createdAt])
}

model AgentSkill {
  id      Int @id @default(autoincrement())
  agentId Int
  skillId Int

  agent Agent @relation(fields: [agentId], references: [id])
  skill Skill @relation(fields: [skillId], references: [id])

  @@unique([agentId, skillId])
}
